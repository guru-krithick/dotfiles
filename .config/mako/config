font=JetBrainsMono Nerd Font 10
background-color=#1a1a1aee
text-color=#e8e8e8
border-color=#3a3a3a
border-size=2
border-radius=10
padding=12
margin=10
default-timeout=5000

width=380
height=130
max-history=20
sort=-time

anchor=top-right
outer-margin=10

icons=1
max-icon-size=48
icon-location=left
icon-border-radius=8

on-button-left=dismiss
on-button-right=dismiss-all

[urgency=critical]
border-color=#a08080
default-timeout=0

[urgency=low]
border-color=#3a3a3a
default-timeout=3000
