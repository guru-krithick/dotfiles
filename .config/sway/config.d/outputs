# Monitor configuration
# External: Dell S2425HSM 24" (left) — primary
# Built-in: AU Optronics 14" (right)

output HDMI-A-1 {
    resolution 1920x1080@120Hz
    position 0 0
}

output eDP-1 {
    resolution 1920x1080@60Hz
    position 1920 0
}

# Workspace assignment
# 1-5 → External (Dell), fallback to Laptop if not connected
# 6-10 → Laptop
workspace 1 output HDMI-A-1 eDP-1
workspace 2 output HDMI-A-1 eDP-1
workspace 3 output HDMI-A-1 eDP-1
workspace 4 output HDMI-A-1 eDP-1
workspace 5 output HDMI-A-1 eDP-1
workspace 6 output eDP-1
workspace 7 output eDP-1
workspace 8 output eDP-1
workspace 9 output eDP-1
workspace 10 output eDP-1

# Focus the external monitor on startup
focus output HDMI-A-1
